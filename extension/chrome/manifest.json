{
  "manifest_version": 3,
  "name": "MomentumAI Job Analyzer",
  "version": "0.1.0",
  "description": "Analyze job postings in MomentumAI from any careers page.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyze in MomentumAI"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
