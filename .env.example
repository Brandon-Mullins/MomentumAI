PORT=3001
NODE_ENV=development
REQUEST_BODY_LIMIT=5mb
ALLOWED_ORIGINS=http://localhost:5173
ALLOW_DEMO_AUTH=true

# Frontend. Leave blank for same-origin /api or Vite dev proxy.
VITE_API_BASE_URL=

# Optional for persistence. Without these, the MVP runs with in-memory demo data.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
